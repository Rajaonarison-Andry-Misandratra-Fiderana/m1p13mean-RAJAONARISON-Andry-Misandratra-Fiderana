# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/shopping-mall
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/shopping-mall

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_use_minimum_32_characters

# CORS Configuration (optional)
CORS_ORIGIN=http://localhost:4200

# Email Configuration (optional for future use)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password

# Logging (optional)
LOG_LEVEL=debug
